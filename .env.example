# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
ADMIN_PASSWORD=promijeni_ovo

# ── Shop konfiguracija ────────────────────────────────────────────────────────
SHOP_NAME=Moj Shop
SHOP_DOMAIN=moj-shop.at
SHOP_LANG=de

# Extra CORS origins (opcionalno, comma-separated)
# CORS_ORIGINS=https://preview.digitalnature.at

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tvoj@email.at
SMTP_PASS=app_password
SMTP_FROM=Iris Shop <tvoj@email.at>

# ── Telegram notifikacije ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
ADMIN_TELEGRAM_ID=123456789

# ── Cron schedule (Vienna timezone) ──────────────────────────────────────────
SYNC_CRON=0 6 * * *
SUMMARY_CRON=0 7 * * *
